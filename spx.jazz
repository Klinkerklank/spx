  stack u8[SPX_N] digest;
  digest, adrs = F(digest, pkseed, adrs, m1);

  // write digest into C buffer manually
  for i = 0 to SPX_N {
	[:u8 (out + i)] = digest[i];
  }

  reg u8 r;
  r = 0;
  return r;
}

export
fn test_H(reg u64 out) -> reg u8 {
  stack u8[SPX_N] pkseed;
  stack u32[8] adrs;
  stack u8[2*SPX_N] m2;

  inline int i;
  for i = 0 to SPX_N {
	pkseed[i] = 0x00;
  }
  for i = 0 to 8 {
	adrs[i] = 0x00000000;
  }
  for i = 0 to 2*SPX_N {
	m2[i] = 0x00;
  }

  stack u8[SPX_N] digest;
  digest, adrs = H(digest, pkseed, adrs, m2);

  // write digest into C buffer manually
  for i = 0 to SPX_N {
	[:u8 (out + i)] = digest[i];
  }

  reg u8 r;
  r = 0;
  return r;
}

export
fn test_T_len(reg u64 out) -> reg u8 {
  stack u8[SPX_N] pkseed;
  stack u32[8] adrs;
  stack u8[SPX_LEN*SPX_N] mlen;

  inline int i;
  for i = 0 to SPX_N {
	pkseed[i] = 0x00;
  }
  for i = 0 to 8 {
	adrs[i] = 0x00000000;
  }
  for i = 0 to SPX_LEN*SPX_N {
	mlen[i] = 0x00;
  }

  stack u8[SPX_N] digest;
  digest, adrs = T_len(digest, pkseed, adrs, mlen);

  // write digest into C buffer manually
  for i = 0 to SPX_N {
	[:u8 (out + i)] = digest[i];
  }

  reg u8 r;
  r = 0;
  return r;
}

export
fn test_T_k(reg u64 out) -> reg u8 {
  stack u8[SPX_N] pkseed;
  stack u32[8] adrs;
  stack u8[SPX_K*SPX_N] mk;

  inline int i;
  for i = 0 to SPX_N {
	pkseed[i] = 0x00;
  }
  for i = 0 to 8 {
	adrs[i] = 0x00000000;
  }
  for i = 0 to SPX_K*SPX_N {
	mk[i] = 0x00;
  }

  stack u8[SPX_N] digest;
  digest, adrs = T_k(digest, pkseed, adrs, mk);

  // write digest into C buffer manually
  for i = 0 to SPX_N {
	[:u8 (out + i)] = digest[i];
  }

  reg u8 r;
  r = 0;
  return r;
}

export
fn test_wots(reg u64 pk_addr pksig_addr sig_addr) -> reg u8 {
  () = #spill(pk_addr, pksig_addr, sig_addr);

  stack u8[SPX_N] pk;
  stack u8[SPX_N] pksig;
  stack u8[SPX_LEN * SPX_N] sig;

  stack u8[SPX_N] skseed;
  stack u8[SPX_N] pkseed;
  stack u32[8] adrs;
  stack u8[SPX_N] m;

  inline int i;
  for i=0 to SPX_N {
	skseed[i] = 0x00;
	pkseed[i] = 0x00;
	m[i]      = 0x00;
  }
  for i=0 to 8 {
	adrs[i] = 0x00000000;
  }

  pk,    adrs = wots_pkgen(pk, skseed, pkseed, adrs);
  sig,   adrs = wots_sign(sig, m, skseed, pkseed, adrs);
  pksig, adrs = wots_pkfromsig(pksig, sig, m, pkseed, adrs);

  () = #unspill(pk_addr, pksig_addr, sig_addr);

  // write into C buffer manually
  for i=0 to SPX_N {
	[:u8 pk_addr + i]    = pk[i];
	[:u8 pksig_addr + i] = pksig[i];
  }
  for i=0 to SPX_LEN*SPX_N { [:u8 sig_addr + i] = sig[i]; }

  reg u8 r;
  r = 0;
  return r;
}

