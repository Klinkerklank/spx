require "params/params-spx-sha2-128f.jinc" // SPHINCS+ parameters
require "adrs/adrs.jinc" // ADRS data structure
require "hash/hash.jinc" // hash function implementations

// require "misc.jinc"      // algorithms 1-4   of SLH-DSS
require "wots/wots.jinc" // algorithms 5-8   of SLH-DSS
// require "xmss/xmss.jinc" // algorithms 9-11  of SLH-DSS
// require "ht/ht.jinc"     // algorithms 12-13 of SLH-DSS
// require "fors/fors.jinc" // algorithms 14-17 of SLH-DSS
// require "spx/spx.jinc"   // algorithms 18-23 of SLH-DSS

export
fn test_ADRS(reg u64 adrs_addr adrsc_addr) -> reg u8
{
  stack u32[8] adrs;
  adrs = adrs_init(adrs);

  reg u32 tmp;
  tmp = 0x111122ff;
  adrs = adrs_set_layer_addr(adrs, tmp);
  stack u32[3] tmp3;
  tmp3[0] = 0x33334444;
  tmp3[1] = 0xaaaabbbb;
  tmp3[2] = 0xccccdddd;
  adrs = adrs_set_tree_addr(adrs, tmp3);
  tmp = 0x555566ff;
  adrs = adrs_set_type_and_clear(adrs, tmp);
  tmp = 0xaaaabbbb;
  adrs = adrs_set_key_pair_addr(adrs, tmp);
  tmp = 0xccccdddd;
  adrs = adrs_set_chain_addr(adrs, tmp);
  tmp = 0xeeeeffff;
  adrs = adrs_set_hash_addr(adrs, tmp);

  inline int i;
  for i=0 to 8 {
	[:u32 (adrs_addr + 4*i)] = adrs[i];
  }

  stack u8[22] adrsc;
  adrsc = adrs_compress(adrsc, adrs);

  for i=0 to 22 {
	[:u8 (adrsc_addr + i)] = adrsc[i];
  }

  reg u8 r;
  r = 0x0;
  return r;
}

export
fn test_adrsc(reg u64 adrs_addr) -> reg u8
{
  stack u32[8] adrs;
  adrs = adrs_init(adrs);

  reg u32 tmp;
  tmp = 0x11112222;
  adrs = adrs_set_layer_addr(adrs, tmp);
  stack u32[3] tmp3;
  tmp3[0] = 0xaaaabbbb;
  tmp3[1] = 0xccccdddd;
  tmp3[2] = 0xeeeeffff;
  adrs = adrs_set_tree_addr(adrs, tmp3);
  tmp = 0x33334444;
  adrs = adrs_set_type_and_clear(adrs, tmp);
  tmp = 0x55556666;
  adrs = adrs_set_key_pair_addr(adrs, tmp);
  tmp = 0x77778888;
  adrs = adrs_set_chain_addr(adrs, tmp);
  tmp = 0x99990000;
  adrs = adrs_set_hash_addr(adrs, tmp);

  stack u8[22] adrsc;
  adrsc = adrs_compress(adrsc, adrs);

  inline int i;
  for i=0 to 8 {
	[:u32 (adrs_addr + 4*i)] = adrs[i];
  }

  reg u8 r;
  r = 0x0;
  return r;
}

export
fn test_H_msg(reg u64 out m mlen) -> reg u8 {
  stack u8[SPX_N] R pkseed pkroot;

  inline int i;
  for i = 0 to SPX_N {
	R[i]      = 0x00;
	pkseed[i] = 0x00;
	pkroot[i] = 0x00;
  }

  stack u8[SPX_M] digest;
  digest = H_msg(digest, R, pkseed, pkroot, m, mlen);

  // write digest into C buffer manually
  for i = 0 to SPX_M {
	[:u8 (out + i)] = digest[i];
  }

  reg u8 r;
  r = 0;
  return r;
}

export
fn test_PRF_msg(reg u64 out m mlen) -> reg u8 {
  stack u8[SPX_N] skprf opt_rand;

  inline int i;
  for i = 0 to SPX_N {
	skprf[i]    = 0x00;
