}

export
fn test_PRF(reg u64 out) -> reg u8 {
  stack u8[SPX_N] pkseed skseed;
  stack u32[8] adrs;

  inline int i;
  for i = 0 to SPX_N {
	pkseed[i] = 0x00;
	skseed[i] = 0x00;
  }
  for i = 0 to 8 {
	adrs[i] = 0x00000000;
  }

  stack u8[SPX_N] digest;
  digest, adrs = PRF(digest, pkseed, skseed, adrs);

  // write digest into C buffer manually
  for i = 0 to SPX_N {
	[:u8 (out + i)] = digest[i];
  }

  reg u8 r;
  r = 0;
  return r;
}

