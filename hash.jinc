inline fn F(
    stack u8[SPX_N] pkseed,
    stack u32[8] adrs,
    stack u8[SPX_N] m1
) -> stack u8[SPX_N]
{
    // declare a stack buffer that will contain the concatenated inputs
    stack u8[2*SPX_N + 32] buf;

    inline int i;

    // 1. copy PK.seed
    for i = 0 to SPX_N {
        buf[i] = pkseed[i];
    }

    // 2. copy ADRS
    // ADRS consists of 32-bit words, the bytes of which are Little Endian. SHA256 expects Big Endian.
    // Hence we write the four bytes in a word in the reverse order into the buffer.
    reg u32 adrs_word;
    for i = 0 to 8 {
        adrs_word = adrs[i];
        buf[SPX_N + 4*i + 3] = adrs_word; // automatically truncates adrs_word to the rightmost 8 bits
        adrs_word >>= 8;
        buf[SPX_N + 4*i + 2] = adrs_word; // automatically truncates adrs_word to the rightmost 8 bits
        adrs_word >>= 8;
        buf[SPX_N + 4*i + 1] = adrs_word; // automatically truncates adrs_word to the rightmost 8 bits
        adrs_word >>= 8;
        buf[SPX_N + 4*i + 0] = adrs_word; // automatically truncates adrs_word to the rightmost 8 bits
    }

    // 3. copy M_1
    for i = 0 to SPX_N {
        buf[SPX_N + 32 + i] = m1[i];
    }

    // declare a stack buffer that will hold the full message digest
    stack u8[32] digest;
    digest = sha256_2n32::__sha256(digest, buf);

    // truncate the message digest to the correct length by copying only the first SPX_N bytes
    stack u8[SPX_N] trunc;
    for i = 0 to SPX_N {
        trunc[i] = digest[i];
    }

    return trunc;
}

fn H(
    stack u8[SPX_N] pkseed,
    stack u32[8] adrs,
    stack u8[2*SPX_N] m2
) -> stack u8[SPX_N]
{
    // declare a stack buffer that will contain the concatenated inputs
    stack u8[3*SPX_N + 32] buf;

    inline int i;

    // 1. copy PK.seed
    for i = 0 to SPX_N {
        buf[i] = pkseed[i];
    }

    // 2. copy ADRS
    // ADRS consists of 32-bit words, the bytes of which are Little Endian. SHA256 expects Big Endian.
    // Hence we write the four bytes in a word in the reverse order into the buffer.
    reg u32 adrs_word;
    for i = 0 to 8 {
        adrs_word = adrs[i];
        buf[SPX_N + 4*i + 3] = adrs_word; // automatically truncates adrs_word to the rightmost 8 bits
        adrs_word >>= 8;
        buf[SPX_N + 4*i + 2] = adrs_word; // automatically truncates adrs_word to the rightmost 8 bits
        adrs_word >>= 8;
        buf[SPX_N + 4*i + 1] = adrs_word; // automatically truncates adrs_word to the rightmost 8 bits
        adrs_word >>= 8;
        buf[SPX_N + 4*i + 0] = adrs_word; // automatically truncates adrs_word to the rightmost 8 bits
    }

    // 3. copy M_2
    for i = 0 to 2*SPX_N {
        buf[SPX_N + 32 + i] = m2[i];
    }

    // declare a stack buffer that will hold the full message digest
    stack u8[32] digest;
    digest = sha256_3n32::__sha256(digest, buf);

    // truncate the message digest to the correct length by copying only the first SPX_N bytes
    stack u8[SPX_N] trunc;
    for i = 0 to SPX_N {
        trunc[i] = digest[i];
    }

    return trunc;
}

